{
  "version": 1,
  "bot": {
    "name": "RSS Dispatch Bot",
    "timezone": "America/Chicago"
  },
  "discord": {
    "guildIdEnv": "DISCORD_GUILD_ID"
  },
  "settings": {
    "polling": {
      "defaultIntervalSeconds": 300,
      "fetchTimeoutSeconds": 10,
      "maxEntriesPerFeed": 30,
      "maxConcurrentFeedFetches": 10,
      "postOldArticlesOnFirstRun": false
    },
    "dedupe": {
      "titleMatchWindowHours": 24
    },
    "timestamps": {
      "allowedFutureSkewMinutes": 5,
      "useIngestedTimeWhenMissing": true,
      "storeRawTimestamps": true,
      "maxPostAgeHours": 48
    },
    "publishing": {
      "secondsBetweenPostsPerChannel": 1.0,
      "maxQueueSizePerChannel": 250
    },
    "logging": {
      "auditEnabled": false,
      "detailedErrors": false,
      "auditLogPath": "logs/rssbot-audit.log",
      "errorLogPath": "logs/rssbot-errors.log",
      "maxBytes": 10485760,
      "backupCount": 5
    },
    "routing": {
      "enabled": false,
      "mode": "observe_only",
      "configDir": "config/routing"
    }
  },
  "channels": [
    {
      "key": "world-news",
      "name": "World News",
      "discordChannelId": "111111111111111111",
      "pollIntervalSeconds": 300,
      "feeds": [
        {
          "name": "CBS World",
          "url": "https://www.cbsnews.com/latest/rss/world"
        },
        {
          "name": "AP World",
          "url": "https://apnews.com/rss/world"
        }
      ]
    },
    {
      "key": "politics",
      "name": "Politics",
      "discordChannelId": "222222222222222222",
      "pollIntervalSeconds": 300,
      "feeds": [
        {
          "name": "CBS Politics",
          "url": "https://www.cbsnews.com/latest/rss/politics"
        }
      ]
    },
    {
      "key": "defense",
      "name": "Defense",
      "discordChannelId": "333333333333333333",
      "pollIntervalSeconds": 600,
      "feeds": [
        {
          "name": "Defense News",
          "url": "https://example.com/defense/rss"
        }
      ]
    },
    {
      "key": "science-technology",
      "name": "Science Technology",
      "discordChannelId": "444444444444444444",
      "pollIntervalSeconds": 300,
      "feeds": [
        {
          "name": "CBS Technology",
          "url": "https://www.cbsnews.com/latest/rss/technology"
        },
        {
          "name": "ABC Business",
          "url": "http://feeds.abcnews.com/abcnews/moneyheadlines"
        }
      ]
    }
  ]
}
