{
  "version": 1,
  "bot": {
    "name": "RSS Dispatch Bot",
    "timezone": "America/Chicago"
  },
  "discord": {
    "guildIdEnv": "DISCORD_GUILD_ID"
  },
  "settings": {
    "polling": {
      "defaultIntervalSeconds": 300,
      "fetchTimeoutSeconds": 10,
      "maxEntriesPerFeed": 30,
      "maxConcurrentFeedFetches": 10,
      "maxConcurrentEmailFetches": 4,
      "resultProcessorWorkers": 2,
      "backlogDrainEnabled": true,
      "postOldArticlesOnFirstRun": false
    },
    "failureBackoff": {
      "enabled": true,
      "minorFailureThreshold": 10,
      "majorFailureThreshold": 100,
      "suspendFailureThreshold": 500,
      "minorRetrySeconds": 21600,
      "majorRetrySeconds": 86400,
      "suspendedRetrySeconds": 604800
    },
    "dedupe": {
      "titleMatchWindowHours": 24
    },
    "timestamps": {
      "allowedFutureSkewMinutes": 5,
      "useIngestedTimeWhenMissing": true,
      "storeRawTimestamps": true,
      "maxPostAgeHours": 24
    },
    "publishing": {
      "secondsBetweenPostsPerChannel": 1.0,
      "maxQueueSizePerChannel": 250,
      "shutdownDrainSeconds": 20
    },
    "logging": {
      "auditEnabled": false,
      "detailedErrors": false,
      "auditLogPath": "logs/rssbot-audit.log",
      "errorLogPath": "logs/rssbot-errors.log",
      "maxBytes": 2097152,
      "backupCount": 3
    },
    "maintenance": {
      "enabled": true,
      "intervalHours": 12,
      "articleRetentionDays": 30,
      "postedRetentionDays": 30,
      "nonPostRetentionHours": 24,
      "seenRetentionDays": 14,
      "feedEntrySeenRetentionDays": 90,
      "articleBatchSize": 1000,
      "optimizeOnMaintenance": true,
      "vacuumOnStartup": false
    },
    "routing": {
      "enabled": true,
      "mode": "observe_only",
      "configDir": "config/routing",
      "maxRoutingSummaryChars": 2000
    }
  },
  "feeds": [
    {
      "id": "reuters-world",
      "sourceId": "reuters",
      "sourceClass": "wire_service",
      "name": "Reuters World",
      "url": "https://example.com/reuters-world.rss",
      "pollIntervalSeconds": 300,
      "initialBackfillHours": 24,
      "routePolicy": "normal",
      "routingTags": [],
      "legacyChannelKeys": ["middle-east"],
      "mirrorChannelKeys": []
    },
    {
      "id": "defense-gov-news",
      "sourceId": "defense-gov",
      "sourceClass": "official_us_defense",
      "name": "Defense.gov News",
      "url": "https://example.com/defense-gov.rss",
      "pollIntervalSeconds": 600,
      "initialBackfillHours": 24,
      "routePolicy": "normal",
      "routingTags": ["military", "government"],
      "legacyChannelKeys": ["dept-of-war"]
    }
  ],
  "channels": [
    {
      "key": "middle-east",
      "name": "Middle East",
      "discordChannelId": "111111111111111111"
    },
    {
      "key": "industrial-base",
      "name": "Industrial Base",
      "discordChannelId": "222222222222222222"
    },
    {
      "key": "reuters",
      "name": "Reuters",
      "discordChannelId": "333333333333333333"
    },
    {
      "key": "dept-of-war",
      "name": "Department of War",
      "discordChannelId": "444444444444444444"
    },
    {
      "key": "review",
      "name": "Review",
      "discordChannelId": "555555555555555555"
    }
  ]
}
